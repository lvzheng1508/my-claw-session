= '- Google: Agent Development Kit (ADK)\\n'\nassert old_ref in content\ncontent = content.replace(old_ref, '', 1)\n\n# Clean up any double newlines left by row removals\nimport re\ncontent = re.sub(r'\\n{3,}', '\\n\\n', content)\n\nwith open('Harness技术实践对比.md', 'w', encoding='utf-8') as f:\n    f.write(content)\nprint('Done - ADK chapter removed, all renumbered')\nPYEOF"}}],"api":"openai-completions","provider":"zai","model":"glm-5-turbo","usage":{"input":336,"output":697,"cacheRead":115139,"cacheWrite":0,"totalTokens":116172,"cost":{"input":0.0004032,"output":0.0027879999999999997,"cacheRead":0.02763336,"cacheWrite":0,"total":0.030824559999999997}},"stopReason":"toolUse","timestamp":1775310097599,"responseId":"202604042141395db177c3cd274c61"}}
